# Environment configuration for the Devin enterprise scripts.
#
# Copy this file to `.env` and fill in your values:
#   cp .env.example .env
#
# All scripts (export_orgs.py, set_local_agent_acu_limits.py,
# set_local_agent_acu_limits_bulk.py) load `.env` automatically from the current
# directory, falling back to the script's own directory. Real environment
# variables and values passed on the command line take precedence over anything
# set here, so `.env` is only used to fill in what isn't already provided.
#
# Do NOT commit your real `.env` (it contains a secret token) -- only this
# example file.

# REQUIRED: a service-user bearer token (prefix: cog_) with the appropriate
# enterprise permission:
#   - export_orgs.py                    -> ManageOrganizations
#   - set_local_agent_acu_limits*.py    -> ManageBilling
DEVIN_SERVICE_USER_TOKEN=

# OPTIONAL: override the API base URL for dedicated enterprise deployments.
# This must point at the API, not the web app -- dedicated deployments usually
# serve the API under the `/api` path of the same host, e.g.
#   https://mycompany.devinenterprise.com/api
# (pointing at the bare web-app host returns HTML). Defaults to the value below.
# DEVIN_API_BASE_URL=https://api.devin.ai
