# Operational configuration for the governance engine.
#
# Copy this file to `config.toml` and fill in your tenant-specific values:
#   cp config.toml.example config.toml
#
# Secrets and host come from the environment / .env (never commit them):
#   DEVIN_SERVICE_USER_TOKEN  — service-user token (prefix cog_)
#   DEVIN_API_BASE_URL        — e.g. https://<company>.devinenterprise.com/api

[paths]
limits_policy = "limits.toml"     # per-org ACU limit (existing)
roles_policy  = "roles.toml"      # per-org desired enterprise role
overrides     = "overrides.toml"  # per-user source-of-truth exceptions
audit_log     = "audit.jsonl"     # append-only audit log (who/what/when/why/triggered-by)
state_dir     = "state"           # snapshots + plan/resume files

[governance]
# A user whose ENTERPRISE role name contains any of these (case-insensitive) is
# treated as an ADMIN: allowed in multiple orgs and exempt from the single-org
# rule and from enterprise-ROLE governance. Their ACU LIMIT is still governed,
# sourced from the Admin Org below (overrides.toml still wins).
admin_role_name_contains = ["Admin"]
# The org whose limits.toml entry provides every admin's ACU limit. An admin who
# is not a member of this org still gets its limit, but reconcile flags them.
admin_org_name = "Admin Org"

[leaver]
# On offboard, zero the limit, remove the user from ALL orgs, then set this
# enterprise role. `limit` is the reclaimed cap (0 = zeroed; "null" = unlimited).
# role_id values come from GET /v3/enterprise/roles.
enterprise_role_id = "role-REPLACE_WITH_LEAVER_ROLE_ID"  # e.g. "Member"
limit = 0

[utilization]
# Near-cap detection (detection only; emits candidates for the `reconcile --user X --limits-only` upgrade).
near_cap_pct      = 0.8   # flag users at >= 80% of their cap
trend_window_days = 14    # look-back window for the recent-vs-prior usage trend
cycle_days        = 30    # window summed as "this cycle" usage vs the per-user cap
# Consumption products that count toward the Local Agent cap. Empty = use the
# endpoint's total_acus. The daily endpoint splits usage into devin / cascade /
# terminal / review; set e.g. ["cascade", "terminal"] to count only local-agent
# usage (verify against your billing definition before relying on it).
products          = []

[invite]
# `onboard` invites new users from a CSV/.xlsx roster, then adds them to the
# named org. The invite grants the org's ENTERPRISE role (from roles.toml); the
# per-org member role below is what new members get inside their org.
# Provide EITHER org_role_id (exact, preferred) OR org_role_name (resolved
# against GET /v3/enterprise/roles at runtime). If neither resolves, `onboard`
# prints the available org roles so you can fill one in.
org_role_name = "Organization User"
# org_role_id = "role-REPLACE_WITH_ORG_MEMBER_ROLE_ID"

[api]
# Cross-cutting resilience: resumable partial-failure handling + retry on rate limit.
rate_limit_sleep_seconds = 0.1
max_retries              = 5
retry_backoff_seconds    = 2.0
# Parallel workers for per-user reads (e.g. reconcile's per-user limit fetch),
# which are network-latency bound and otherwise run one-at-a-time. Raise to go
# faster; lower (1 = serial) if you hit rate limits — 429s are retried with
# backoff regardless.
read_concurrency         = 8
# Parallel workers for APPLYING a plan: each user's changes (e.g. invite ->
# org-add -> limit) run concurrently across users, while changes within a user
# stay sequential. Applies to EVERY plan kind — large onboard/offboard/reassign
# and reconcile applies alike. Lower (1 = serial) if you hit rate limits; 429s
# are retried with backoff regardless.
apply_concurrency        = 8
